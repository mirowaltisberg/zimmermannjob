# Shared Supabase project (all 10 QERO job sites)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<...>

# Per-site canonical domain (overrides the code-level fallback in app/layout.tsx etc.)
NEXT_PUBLIC_SITE_URL=https://www.<site>.ch

# Optional: scraper freshness window (jobs older than this are re-scraped). Default 72.
SCRAPE_STALE_HOURS=72
